yarn.lock

# Git & VCS
.git
.gitignore

# Docker
Dockerfile
.dockerignore
docker-compose.yml

# Env / secrets (never bake into the image)
.env
.env.*
*.pem

# Editor / OS junk
.vscode
.idea
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc
README.md
LICENSE
.vercel
